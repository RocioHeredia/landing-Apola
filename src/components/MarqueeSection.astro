---
const palabras = [
  'Elegancia', 'Estilo', 'Diseño', 'Moda', 'Tendencias',
  'Calidad', 'Colección', 'Feminidad', 'Vanguardia', 'Sofisticación',
  'Minimalismo', 'Contemporáneo', 'San Juan', 'Apola',
];
---

<div class="w-full overflow-hidden" style="background:#d9c5b2; padding: 0.75rem 0; margin-top:-3rem;">
  <div class="marquee-track flex gap-12 whitespace-nowrap">
    {[...palabras, ...palabras].map(p => (
      <span class="font-display text-[14px] italic flex-shrink-0 flex items-center gap-12" style="color:#262626;">
        {p}
        <span class="font-body text-[9px] tracking-widest not-italic" style="color:#262626; opacity:0.4;">·</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 28s linear infinite;
    width: max-content;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
